# Files in the repo root that must NOT be uploaded as static assets.
# (gitignore syntax; read by wrangler from the assets directory)
.git
.gitignore
.assetsignore
.dev.vars
# Any *.local file is a local-only secret and must never be served. The
# repo root IS this Worker's asset directory, so a file that is merely
# gitignored still gets published unless it is listed here too.
*.local
.wrangler
.claude
node_modules
wrangler.toml
worker
tools
docs
data
partials
inc
crm
CLAUDE.md
estateprime-api-doc.yaml
# dev-only form autofill helper — never ship to production
forms/_autofill.dev.js
# Unadapted "Homy" template demo pages + their template-only images, kept
# in the repo as raw reference material (see docs/architecture.md). The
# whole folder is reference-only and never served — grouping them here
# replaced ~45 individual filename entries.
template
# Master brand source files (brand PDF, spare logo lockups) — not web
# assets; see docs/brand.md.
brand
# theme sources / sourcemaps — internal, don't ship
scss
css/*.map
css/style.css
# unused by any page (icons load via style.fw.min.css -> fonts/bootstrap-icons-1.11.1)
css/bootstrap-icons.css
css/bootstrap-icons.min.css
