# local secrets for wrangler dev
.dev.vars
# wrangler cache / local KV state
.wrangler/
node_modules/
# generated listings feed (production copy lives in Workers KV)
data/
# webhook shared secret (copy into EstatePrime; never commit)
.webhook-key.local
# disposable EstatePrime test keys
.estateprime-test.local
# every *.local file is a local-only secret. The glob is the safety net:
# these kept being added one by one, and the repo root doubles as the
# Worker's asset directory — a missed entry is published, not just
# committed. Keep the twin entry in .assetsignore.
*.local
